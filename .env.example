# =============================================================================
# Victory Martin — Apt.Bed · Environment configuration
# Copy to `.env` and fill in. Never commit real secrets.
# =============================================================================

# --- Database ---------------------------------------------------------------
# DEV (default): local SQLite file. Uses `provider = "sqlite"` in schema.prisma.
DATABASE_URL="file:./dev.db"
#
# PRODUCTION (Neon / PostgreSQL): switch schema.prisma datasource to
#   provider = "postgresql"
#   url      = env("DATABASE_URL")
#   directUrl = env("DIRECT_URL")
# then set the pooled + direct connection strings from Neon:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require"

# --- Auth (NextAuth / Auth.js) ----------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-with-a-32-byte-random-string"
# Public URL of the deployed site (used for callbacks + email links).
NEXTAUTH_URL="https://victorymartin.com"

# --- Payments (Stripe) ------------------------------------------------------
# Leave STRIPE_SECRET_KEY blank in dev to use the built-in mock checkout.
# Use sk_test_... for staging and sk_live_... in production.
STRIPE_SECRET_KEY=""
# From the Stripe dashboard webhook endpoint (whsec_...). Required in prod so
# order payment status is confirmed reliably.
STRIPE_WEBHOOK_SECRET=""

# --- Sales tax --------------------------------------------------------------
# "table"  = data-driven US state rates from the DB (default, offline).
# "stripe" = Stripe Tax (requires Stripe keys).
TAX_MODE="table"

# --- Email (Mailgun) --------------------------------------------------------
# Blank = confirmations logged to the server console. Set both to send.
MAILGUN_API_KEY=""
# The verified Mailgun sending domain (e.g. mg.victorymartin.com).
MAILGUN_DOMAIN=""
# From address (must belong to the verified domain).
MAILGUN_FROM="Victory Martin <orders@victorymartin.com>"
# EU region only: uncomment.
# MAILGUN_API_BASE="https://api.eu.mailgun.net"

# --- Media storage (Cloudinary) ---------------------------------------------
# Blank = local /public/uploads (dev only — Railway's filesystem is ephemeral).
# Set CLOUDINARY_URL to store uploads durably in production.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=""
# ...or the individual vars instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# --- Freight shipping -------------------------------------------------------
# "flat"    = single admin-editable flat rate (default).
# "carrier" = live carrier-rate provider (falls back to flat until configured).
FREIGHT_PROVIDER="flat"
# Credentials for the live freight/LTL carrier rating API (M3 integration).
FREIGHT_CARRIER_API_KEY=""
FREIGHT_CARRIER_URL=""
