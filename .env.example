# =============================================================================
# Victory Martin — Apt.Bed · Environment configuration
# Copy to `.env` and fill in. Never commit real secrets.
# =============================================================================

# --- Database ---------------------------------------------------------------
# DEV (default): local SQLite file. Uses `provider = "sqlite"` in schema.prisma.
DATABASE_URL="file:./dev.db"
#
# PRODUCTION (self-hosted PostgreSQL on the VPS): switch schema.prisma datasource to
#   provider = "postgresql"
#   url      = env("DATABASE_URL")
#   directUrl = env("DIRECT_URL")
# Postgres runs on localhost, so both URLs are identical (no pooler):
# DATABASE_URL="postgresql://aptbed:password@localhost:5432/aptbed?schema=public"
# DIRECT_URL="postgresql://aptbed:password@localhost:5432/aptbed?schema=public"

# --- Auth (NextAuth / Auth.js) ----------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-with-a-32-byte-random-string"
# Public URL of the deployed site (used for callbacks + email links).
NEXTAUTH_URL="https://apartmentloftbed.com"

# --- Payments (Stripe) ------------------------------------------------------
# Leave STRIPE_SECRET_KEY blank in dev to use the built-in mock checkout.
# Use sk_test_... for staging and sk_live_... in production.
STRIPE_SECRET_KEY=""
# From the Stripe dashboard webhook endpoint (whsec_...). Required in prod so
# order payment status is confirmed reliably.
STRIPE_WEBHOOK_SECRET=""

# --- Sales tax --------------------------------------------------------------
# "table"  = data-driven US state rates from the DB (default, offline).
# "stripe" = Stripe Tax (requires Stripe keys).
TAX_MODE="table"

# --- Email (Resend) ---------------------------------------------------------
# Blank = order/reset confirmations logged to the server console. Set to send.
# Create a key at https://resend.com → API Keys (re_...).
RESEND_API_KEY=""
# From address. The domain must be verified in Resend (add the DNS records it
# lists). For quick testing before verifying, use "onboarding@resend.dev".
RESEND_FROM="Victory Martin <orders@apartmentloftbed.com>"

# --- Media storage (Cloudinary) ---------------------------------------------
# Blank = local /public/uploads (dev only).
# Set CLOUDINARY_URL to store uploads off-box on Cloudinary's CDN in production.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=""
# ...or the individual vars instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# --- Freight shipping -------------------------------------------------------
# "flat"    = single admin-editable flat rate (default).
# "carrier" = live carrier-rate provider (falls back to flat until configured).
FREIGHT_PROVIDER="flat"
# Credentials for the live freight/LTL carrier rating API (M3 integration).
FREIGHT_CARRIER_API_KEY=""
FREIGHT_CARRIER_URL=""

# Required to register a new admin via /admin/register (choose a strong secret).
ADMIN_SIGNUP_CODE=""
