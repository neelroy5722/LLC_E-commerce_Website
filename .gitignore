# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# editor atomic-save temp files (e.g. .env.tmp.<pid>.<hash>) — never commit;
# a stray .env.tmp would otherwise carry real secrets into git.
*.tmp.*

# local SQLite dev database (generated by prisma db push + seed)
/prisma/*.db
/prisma/*.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts

# local reference screenshots (not part of the app)
/edit/
